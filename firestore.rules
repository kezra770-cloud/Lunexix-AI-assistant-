rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (optional, 'admin' or 'user')
    //
    // Collection: users/{userId}/playlists
    // Document ID: {playlistId}
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - songs: list (required)
    //   - createdAt: number (required)
    //
    // Collection: users/{userId}/chats
    // Document ID: {mode}
    // Fields:
    //   - uid: string (required)
    //   - mode: string (required)
    //   - messages: list (required)
    //   - updatedAt: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "kezra770@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'email', 'displayName', 'photoURL', 'role']) &&
             data.uid is string &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidPlaylist(data) {
      return data.keys().hasOnly(['uid', 'name', 'songs', 'createdAt']) &&
             data.uid is string &&
             data.name is string && data.name.size() <= 100 &&
             data.songs is list && data.songs.size() <= 1000 &&
             data.createdAt is number;
    }

    function isValidChatHistory(data) {
      return data.keys().hasOnly(['uid', 'mode', 'messages', 'updatedAt']) &&
             data.uid is string &&
             data.mode is string && data.mode.size() <= 50 &&
             data.messages is list && data.messages.size() <= 5000 &&
             data.updatedAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) && hasRequiredFields(['uid', 'email']) && isValidUser(request.resource.data) && uidUnchanged() && (!('role' in request.resource.data) || request.resource.data.role == 'user')) || isAdmin();
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && uidNotModified() && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();

      match /playlists/{playlistId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredFields(['uid', 'name', 'songs', 'createdAt']) && isValidPlaylist(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isValidPlaylist(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId);
      }

      match /chats/{mode} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && hasRequiredFields(['uid', 'mode', 'messages', 'updatedAt']) && isValidChatHistory(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isValidChatHistory(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId);
      }
    }
  }
}