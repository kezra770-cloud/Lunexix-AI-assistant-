{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "A saved playlist",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "songs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "artist": { "type": "string" },
              "coverUrl": { "type": "string" },
              "previewUrl": { "type": "string" },
              "url": { "type": "string" }
            },
            "required": ["id", "title", "artist"]
          }
        },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "songs", "createdAt"]
    },
    "ChatHistory": {
      "title": "ChatHistory",
      "description": "Chat history for a specific mode",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "mode": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string" },
              "text": { "type": "string" },
              "timestamp": { "type": "number" }
            },
            "required": ["role", "text", "timestamp"]
          }
        },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "mode", "messages", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "Saved playlists for the user"
    },
    "/users/{userId}/chats/{mode}": {
      "schema": "ChatHistory",
      "description": "Chat history for each mode"
    }
  }
}
